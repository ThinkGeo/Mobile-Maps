<howDoI:SamplePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                   xmlns:thinkgeo="clr-namespace:ThinkGeo.UI.Maui;assembly=ThinkGeo.UI.Maui"
                   xmlns:howDoI="using:HowDoISample"
                   xmlns:codeBehind="clr-namespace:HowDoISample.XYZBasedLayers"
                   x:DataType="codeBehind:MVT"
                   x:Class="HowDoISample.XYZBasedLayers.MVT">

    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <howDoI:DescriptionView Grid.Row="0"
                Description="{Binding Description, Source={x:Reference BasePage}}" />

            <thinkgeo:MapView Grid.Row="1" x:Name="MapView"
                          SizeChanged="MapView_OnSizeChanged">
                <thinkgeo:MapView.MapTools>
                    <thinkgeo:ZoomMapTool>
                        <thinkgeo:ZoomMapTool.Margin>
                            <OnPlatform x:TypeArguments="Thickness">
                                <On Platform="Android" Value="0,50,0,0" />
                                <On Platform="iOS"     Value="0,50,0,0" />
                                <On Platform="WinUI"  Value="0" />
                            </OnPlatform>
                        </thinkgeo:ZoomMapTool.Margin>
                    </thinkgeo:ZoomMapTool>
                </thinkgeo:MapView.MapTools>
            </thinkgeo:MapView>

            <Picker Grid.Row="1" x:Name="StylePicker" HorizontalOptions="Center" VerticalOptions="Start"
                    WidthRequest="360" FontSize="18" BackgroundColor="Gray" ZIndex="1"
                    ItemsSource="{Binding StyleUris}" SelectedIndex="{Binding SelectedStyleIndex, Mode=TwoWay}"
                    SelectedIndexChanged="StylePicker_OnSelectedIndexChanged" />

        </Grid>
    </ContentPage.Content>
</howDoI:SamplePage>