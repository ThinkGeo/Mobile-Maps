<howDoI:SamplePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                   xmlns:thinkgeo="clr-namespace:ThinkGeo.UI.Maui;assembly=ThinkGeo.UI.Maui"
                   xmlns:howDoI="using:HowDoISample"
                   xmlns:codeBehind="clr-namespace:HowDoISample.VectorDataSpatialQuery"
                   x:DataType="codeBehind:Overlaps"
                   x:Class="HowDoISample.VectorDataSpatialQuery.Overlaps">
    
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <howDoI:DescriptionView Grid.Row="0"
                    Description="{Binding Description, Source={x:Reference BasePage}}" />

            <thinkgeo:MapView Grid.Row="1" x:Name="Map"
                              SizeChanged="Overlaps_OnSizeChanged">
                <thinkgeo:MapView.MapTools> 
                    <thinkgeo:ZoomMapTool/>
                </thinkgeo:MapView.MapTools>
            </thinkgeo:MapView>

        </Grid>
    </ContentPage.Content>
</howDoI:SamplePage>
