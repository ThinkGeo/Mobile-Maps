<howDoI:SamplePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                   xmlns:thinkgeo="clr-namespace:ThinkGeo.UI.Maui;assembly=ThinkGeo.UI.Maui"
                   xmlns:howDoI="using:HowDoISample"
                   xmlns:codeBehind="clr-namespace:HowDoISample.VectorDataGeometricOperation"
                   x:DataType="codeBehind:GetConvexHull"
                   x:Class="HowDoISample.VectorDataGeometricOperation.GetConvexHull">

    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
            </Grid.RowDefinitions>

            <howDoI:DescriptionView Grid.Row="0"
                    Description="{Binding Description, Source={x:Reference BasePage}}" />

            <thinkgeo:MapView Grid.Row="1" x:Name="Map"  Grid.RowSpan="3" 
                              MapUnit="Meter" MapRotation="0" SizeChanged="Map_OnSizeChanged">
                <thinkgeo:MapView.MapTools>
                    <thinkgeo:ZoomMapTool />
                </thinkgeo:MapView.MapTools>
            </thinkgeo:MapView>

            <Button Grid.Row="2" Text="Get Convex Hull" Clicked="ShapeConvexHull_OnClick"
                    TextColor="White" FontAttributes="Bold" BackgroundColor="Gray"
                     WidthRequest="200" HorizontalOptions="Center"/>
        </Grid>
    </ContentPage.Content>
</howDoI:SamplePage>
